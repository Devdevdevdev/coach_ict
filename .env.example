# Optional server-level default key (not required if each user enters their own key)
KIMI_API_KEY=

# Optional endpoint override
KIMI_BASE_URL=https://api.moonshot.ai/v1

# Required for real TradingView data (local connector endpoint)
# Expected route: POST {TRADINGVIEW_BRIDGE_URL}/tool
TRADINGVIEW_BRIDGE_URL=http://127.0.0.1:8787

# Server port
PORT=3000

# Bridge local server
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8787

# Chrome DevTools endpoint (launch Chrome with --remote-debugging-port=9222)
CHROME_DEBUG_URL=http://127.0.0.1:9222
TV_TAB_MATCH=tradingview.com
TV_AUTO_URL=https://fr.tradingview.com/chart/?symbol=VANTAGE%3AXAUUSD
AUTO_START_CHROME=true
CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
CHROME_USER_DATA_DIR=$HOME/.chrome-tv-debug
